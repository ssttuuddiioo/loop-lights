# Set to your ELM server URL for development
# Leave empty to use relative paths (when deployed to ELM server)
VITE_ELM_URL=http://localhost:8057

# Advatek Controller Monitoring
# Format: ip:label,ip:label,...
DIMLY_CONTROLLERS=2.0.0.21:T8-S Unit 1,2.0.0.22:T8-S Unit 2,2.0.0.23:E16-S PJ1,2.0.0.24:A4-S Facade 1
DIMLY_POLL_INTERVAL=30000
DIMLY_CONNECT_TIMEOUT=5000

# Scene Engine
DIMLY_SCENES_PATH=./scenes.json
# DIMLY_ELM_PORT=8057

# Weather (future)
# DIMLY_WEATHER_API_KEY=
# DIMLY_WEATHER_POLL_INTERVAL=600000
